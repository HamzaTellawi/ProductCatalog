@model ProductCatalog.ViewModels.Products.CreateProductViewModel

@{
    ViewData["Title"] = "Add Product";
}

<div class="row justify-content-center">

    <div class="col-xl-8">

        <div class="mb-4">

            <h2 class="fw-bold mb-1">
                Add New Product
            </h2>

            <p class="text-muted mb-0">
                Fill in the information below to create a new product.
            </p>

        </div>

        <div class="card">

            <div class="card-body p-4">

                <form asp-action="Create" method="post">

                    <div class="row">

                        <div class="col-md-6 mb-4">

                            <label asp-for="Name" class="form-label fw-semibold"></label>

                            <input asp-for="Name"
                                   class="form-control"
                                   placeholder="Product name" />

                            <span asp-validation-for="Name"
                                  class="text-danger small"></span>

                        </div>

                        <div class="col-md-6 mb-4">

                            <label asp-for="Price" class="form-label fw-semibold"></label>

                            <div class="input-group">

                                <span class="input-group-text">$</span>

                                <input asp-for="Price"
                                       class="form-control"
                                       placeholder="0.00" />

                            </div>

                            <span asp-validation-for="Price"
                                  class="text-danger small"></span>

                        </div>

                    </div>

                    <div class="mb-4">

                        <label asp-for="Description"
                               class="form-label fw-semibold"></label>

                        <textarea asp-for="Description"
                                  rows="5"
                                  class="form-control"
                                  placeholder="Write a short description..."></textarea>

                        <span asp-validation-for="Description"
                              class="text-danger small"></span>

                    </div>

                    <div class="mb-4">

                        <label asp-for="Stock"
                               class="form-label fw-semibold"></label>

                        <input asp-for="Stock"
                               class="form-control"
                               placeholder="Available quantity" />

                        <span asp-validation-for="Stock"
                              class="text-danger small"></span>

                    </div>

                    <hr class="my-4" />

                    <div class="d-flex justify-content-end gap-2">

                        <a asp-action="Index"
                           class="btn btn-light">

                            <i class="bi bi-arrow-left me-2"></i>

                            Cancel

                        </a>

                        <button type="submit"
                                class="btn btn-primary">

                            <i class="bi bi-check-lg me-2"></i>

                            Save Product

                        </button>

                    </div>

                </form>

            </div>

        </div>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}