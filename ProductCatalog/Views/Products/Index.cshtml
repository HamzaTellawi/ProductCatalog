@model List<ProductCatalog.ViewModels.Products.ProductViewModel>

@{
    ViewData["Title"] = "Products";
}

<div class="d-flex justify-content-between align-items-center mb-4">

    <div>

        <h2 class="fw-bold mb-1">
            Product Catalog
        </h2>

        <p class="text-muted mb-0">
            Manage your products in a modern and simple way.
        </p>

    </div>

    <a asp-action="Create"
       class="btn btn-primary">

        <i class="bi bi-plus-lg me-2"></i>

        Add Product

    </a>

</div>


@if (!Model.Any())
{
    <div class="card">

        <div class="card-body text-center py-5">

            <i class="bi bi-box display-1 text-secondary"></i>

            <h3 class="mt-3">

                No Products

            </h3>

            <p class="text-muted">

                Create your first product.

            </p>

            <a asp-action="Create"
               class="btn btn-primary mt-2">

                Create Product

            </a>

        </div>

    </div>
}
else
{

    <div class="row g-4">

        @foreach (var item in Model)
        {

            <div class="col-xl-4 col-lg-6">

                <div class="card product-card h-100">

                    <div class="card-body">

                        <div class="text-center">

                            <div class="product-image">

                                <i class="bi bi-box-seam"></i>

                            </div>

                            <h5 class="fw-bold mt-4">

                                @item.Name

                            </h5>

                            @if (!string.IsNullOrWhiteSpace(item.CategoryName))
                            {
                                <span class="badge bg-info-subtle text-info mt-2">

                                    <i class="bi bi-tag-fill me-1"></i>

                                    @item.CategoryName

                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary-subtle text-secondary mt-2">

                                    <i class="bi bi-question-circle me-1"></i>

                                    No Category

                                </span>
                            }

                        </div>

                        <hr />

                        <div class="d-flex justify-content-between mb-3">

                            <span class="text-muted">

                                Price

                            </span>

                            <strong>

                                $@item.Price

                            </strong>

                        </div>

                        <div class="d-flex justify-content-between align-items-center">

                            <span class="text-muted">

                                Stock

                            </span>

                            @if (item.Stock > 10)
                            {
                                <span class="badge bg-success-subtle text-success">

                                    @item.Stock Available

                                </span>
                            }
                            else if (item.Stock > 0)
                            {
                                <span class="badge bg-warning-subtle text-warning">

                                    @item.Stock Left

                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger-subtle text-danger">

                                    Out of Stock

                                </span>
                            }

                        </div>

                    </div>

                    <div class="card-footer bg-white border-0">

                        <div class="d-flex justify-content-between">

                            <a asp-action="Details"
                               asp-route-id="@item.Id"
                               class="btn btn-light">

                                <i class="bi bi-eye"></i>

                            </a>

                            <a asp-action="Edit"
                               asp-route-id="@item.Id"
                               class="btn btn-light">

                                <i class="bi bi-pencil"></i>

                            </a>

                            <form asp-action="Delete"
                                  asp-route-id="@item.Id"
                                  method="post">

                                <button class="btn btn-light text-danger"
                                        onclick="return confirm('Delete this product?')">

                                    <i class="bi bi-trash"></i>

                                </button>

                            </form>

                        </div>

                    </div>

                </div>

            </div>

        }

    </div>

}