@model ProductCatalog.ViewModels.Products.EditProductViewModel

@{
    ViewData["Title"] = "Edit Product";
}

<div class="row justify-content-center">

    <div class="col-xl-8">

        <div class="mb-4">

            <h2 class="fw-bold mb-1">
                Edit Product
            </h2>

            <p class="text-muted mb-0">
                Update the product information below.
            </p>

        </div>

        <div class="card">

            <div class="card-body p-4">

                <form asp-action="Edit" method="post">

                    <input asp-for="Id" type="hidden" />

                    <div class="row">

                        <div class="col-md-6 mb-4">

                            <label asp-for="Name" class="form-label"></label>

                            <input asp-for="Name"
                                   class="form-control"
                                   placeholder="Product name" />

                            <span asp-validation-for="Name"
                                  class="text-danger small"></span>

                        </div>

                        <div class="col-md-6 mb-4">

                            <label asp-for="Price" class="form-label"></label>

                            <div class="input-group">

                                <span class="input-group-text">$</span>

                                <input asp-for="Price"
                                       class="form-control"
                                       placeholder="0.00" />

                            </div>

                            <span asp-validation-for="Price"
                                  class="text-danger small"></span>

                        </div>

                    </div>

                    <div class="col-md-6 mb-4">

                        <label asp-for="CategoryId"
                               class="form-label"></label>

                        <select asp-for="CategoryId"
                                asp-items="Model.Categories"
                                class="form-select">

                            <option value="">-- Select Category --</option>

                        </select>

                        <span asp-validation-for="CategoryId"
                              class="text-danger small"></span>

                    </div>

                    <div class="mb-4">

                        <label asp-for="Description"
                               class="form-label"></label>

                        <textarea asp-for="Description"
                                  rows="5"
                                  class="form-control"
                                  placeholder="Product description"></textarea>

                        <span asp-validation-for="Description"
                              class="text-danger small"></span>

                    </div>

                    <div class="mb-4">

                        <label asp-for="Stock"
                               class="form-label"></label>

                        <input asp-for="Stock"
                               class="form-control"
                               placeholder="Available quantity" />

                        <span asp-validation-for="Stock"
                              class="text-danger small"></span>

                    </div>

                    <hr class="my-4" />

                    <div class="d-flex justify-content-between align-items-center">

                        <a asp-action="Index"
                           class="btn btn-light">

                            <i class="bi bi-arrow-left me-2"></i>

                            Back

                        </a>

                        <button type="submit"
                                class="btn btn-warning text-white">

                            <i class="bi bi-pencil-square me-2"></i>

                            Update Product

                        </button>

                    </div>

                </form>

            </div>

        </div>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}