<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>@ViewData["Title"] - Product Catalog</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="preconnect" href="https://fonts.googleapis.com">

    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
          rel="stylesheet">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/ProductCatalog.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />

</head>

<body>

    <div class="app-layout">

        <!-- Sidebar -->

        <aside class="sidebar">

            <div>

                <div class="logo">

                    <div class="logo-icon">
                        <i class="bi bi-box-seam-fill"></i>
                    </div>

                    <div>

                        <h5 class="mb-0">Product Catalog</h5>

                        <small>Management System</small>

                    </div>

                </div>

                <div class="menu mt-5">
                    <a asp-controller="Dashboard"
                       asp-action="Index">

                        <i class="bi bi-speedometer2"></i>

                        <span>Dashboard</span>

                    </a>

                    <hr class="my-3 text-secondary" />
                    <!-- Products -->

                    <a asp-controller="Products"
                       asp-action="Index">

                        <i class="bi bi-grid-1x2-fill"></i>

                        <span>Products</span>

                    </a>

                    <a asp-controller="Products"
                       asp-action="Create">

                        <i class="bi bi-plus-circle-fill"></i>

                        <span>Add Product</span>

                    </a>

                    <hr class="my-3 text-secondary" />

                    <!-- Categories -->

                    <a asp-controller="Categories"
                       asp-action="Index">

                        <i class="bi bi-tags-fill"></i>

                        <span>Categories</span>

                    </a>

                    <a asp-controller="Categories"
                       asp-action="Create">

                        <i class="bi bi-folder-plus"></i>

                        <span>Add Category</span>

                    </a>

                </div>

            </div>

            <div class="version">

                <small>Version 1.0</small>

            </div>

        </aside>

        <!-- Main -->

        <div class="content">

            <!-- Topbar -->

            <header class="topbar">
                <div class="d-flex justify-content-between align-items-center w-100">
                    <div>
                        <h3 class="fw-bold mt-4">
                            @ViewData["Title"]
                        </h3>
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb mb-0">
                            </ol>

                        </nav>

                    </div>
                </div>
            </header>
            <main class="page-content">
                @RenderBody()
            </main>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>

    @await RenderSectionAsync("Scripts", false)

</body>

</html>