@model IEnumerable<ProductCatalog.ViewModels.Categories.CategoryViewModel>

@{
    ViewData["Title"] = "Categories";
}

@if (TempData["Success"] is not null)
{
    <div class="alert alert-success alert-dismissible fade show">

        @TempData["Success"]

        <button type="button"
                class="btn-close"
                data-bs-dismiss="alert"></button>

    </div>
}

@if (TempData["Error"] is not null)
{
    <div class="alert alert-danger alert-dismissible fade show">

        @TempData["Error"]

        <button type="button"
                class="btn-close"
                data-bs-dismiss="alert"></button>

    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">

    <div>

        <h2 class="fw-bold mb-1">
            Categories
        </h2>

        <p class="text-muted mb-0">
            Organize your products into categories.
        </p>

    </div>

    <a asp-action="Create"
       class="btn btn-primary">

        <i class="bi bi-plus-lg me-2"></i>

        Add Category

    </a>

</div>

@if (!Model.Any())
{
    <div class="card">

        <div class="card-body text-center py-5">

            <i class="bi bi-tags display-1 text-secondary"></i>

            <h3 class="mt-3">

                No Categories

            </h3>

            <p class="text-muted">

                Create your first category.

            </p>

            <a asp-action="Create"
               class="btn btn-primary mt-2">

                Create Category

            </a>

        </div>

    </div>
}
else
{
    <div class="card">

        <div class="list-group list-group-flush">

            @foreach (var item in Model)
            {
                <div class="list-group-item category-item">

                    <div class="row align-items-center">

                        <!-- Icon + Name -->

                        <div class="col-md-5">

                            <div class="d-flex align-items-center">

                                <div class="category-icon">

                                    <i class="bi bi-tags-fill"></i>

                                </div>

                                <div class="ms-3">

                                    <h5 class="fw-bold mb-1">

                                        @item.Name

                                    </h5>

                                    <p class="category-description mb-0">

                                        @(string.IsNullOrWhiteSpace(item.Description)
                                            ? "No description available."
                                            : item.Description)

                                    </p>

                                </div>

                            </div>

                        </div>

                        <!-- Products Count -->

                        <div class="col-md-3 text-center">

                            <span class="text-muted d-block mb-1">

                                Products

                            </span>

                            <span class="badge bg-primary px-3 py-2">

                                @item.ProductsCount Products

                            </span>

                        </div>

                        <!-- Actions -->

                        <div class="col-md-4">

                            <div class="d-flex justify-content-end gap-2">

                                <a asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="btn btn-light">

                                    <i class="bi bi-eye"></i>

                                </a>

                                <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-light">

                                    <i class="bi bi-pencil"></i>

                                </a>

                                <form asp-action="Delete"
                                      asp-route-id="@item.Id"
                                      method="post">

                                    <button class="btn btn-light text-danger"
                                            onclick="return confirm('Delete this category?')">

                                        <i class="bi bi-trash"></i>

                                    </button>

                                </form>

                            </div>

                        </div>

                    </div>

                </div>
            }

        </div>

    </div>
}

    </div>
}